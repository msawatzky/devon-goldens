---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import homepage from '../content/singletons/homepage.json';
import contact from '../content/singletons/contact.json';

const [dogs, faqs] = await Promise.all([getCollection('dogs'), getCollection('faqs')]);

const byLabel = (a: (typeof dogs)[number], b: (typeof dogs)[number]) =>
	a.data.label.localeCompare(b.data.label, undefined, { numeric: true });

const parentDogs = dogs.filter((dog) => dog.data.group === 'Parents').sort(byLabel);
const previousLitterPuppies = dogs.filter((dog) => dog.data.group === 'Previous Litter').sort(byLabel);
const currentLitterPuppies = dogs.filter((dog) => dog.data.group === 'Current Litter').sort(byLabel);
const orderedFaqs = [...faqs].sort((a, b) => a.data.order - b.data.order);

const fallbackDogImages = [
	'https://images.unsplash.com/photo-1633722715463-d30f4f325e24?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1612774412771-005ed8e861d2?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1530281700549-e82e7bf110d6?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1601758228041-f3b2795255f1?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&w=1200&q=80',
];

const makeSeed = (input: string) => {
	const hash = [...input].reduce((acc, char) => {
		return (acc * 31 + char.charCodeAt(0)) % 100000;
	}, 7);
	return Math.abs(hash);
};

const getDisplayImage = (entry: (typeof dogs)[number]) => {
	if (entry.data.image.startsWith('http://') || entry.data.image.startsWith('https://')) {
		return entry.data.image;
	}

	const seed = makeSeed(`${entry.data.group}-${entry.data.label}`);
	return fallbackDogImages[seed % fallbackDogImages.length];
};
---

<Layout>
	<main class="mx-auto max-w-7xl px-6 py-10 md:px-10 md:py-14">
		<section>
			<div class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-black/5 md:p-10">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#5E5C2D]/70">Devon Goldens</p>
				<h1 class="mt-4 max-w-2xl text-4xl font-semibold leading-tight text-[#2f2e17] md:text-6xl">
					{homepage?.heroTitle ?? 'Golden Retrievers raised with love'}
				</h1>
				<p class="mt-5 max-w-xl whitespace-pre-line text-base leading-relaxed text-[#5E5C2D]/85 md:text-lg">
					{homepage?.introText ?? 'Healthy, happy puppies from temperament-focused bloodlines.'}
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a href="#gallery" class="rounded-full bg-[#5E5C2D] px-5 py-2.5 text-sm font-medium text-white transition hover:opacity-90">
						View Puppies
					</a>
					<a href="#contact" class="rounded-full border border-[#5E5C2D]/25 bg-white px-5 py-2.5 text-sm font-medium text-[#5E5C2D] transition hover:bg-[#5E5C2D]/5">
						Contact Us
					</a>
				</div>
			</div>
		</section>

		<section class="mt-10 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-black/5 md:p-10">
			<h2 class="text-2xl font-semibold text-[#2f2e17] md:text-3xl">About Us</h2>
			<p class="mt-4 max-w-4xl whitespace-pre-line text-base leading-relaxed text-[#5E5C2D]/90 md:text-lg">{homepage?.aboutUs}</p>
		</section>

		<section id="gallery" class="mt-12">
			<h2 class="text-2xl font-semibold text-[#2f2e17] md:text-3xl">Meet the Parents</h2>
			<div class="mt-6 grid gap-6 sm:grid-cols-2 md:grid-cols-3">
				{parentDogs.map((dog) => (
					<article class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-black/5">
						<button
							type="button"
							class="aspect-[4/3] w-full overflow-hidden rounded-xl bg-neutral-100"
							data-lightbox-src={getDisplayImage(dog)}
							data-lightbox-alt={dog.data.label}
						>
							<img src={getDisplayImage(dog)} alt={dog.data.name} class="h-full w-full object-cover transition hover:scale-105" loading="lazy" />
						</button>
						<div class="mt-4 flex items-center justify-between">
							<h3 class="text-lg font-semibold text-[#2f2e17]">{dog.data.label}</h3>
							{dog.data.role && (
								<span class="rounded-full bg-[#FEC67C]/45 px-3 py-1 text-xs font-semibold text-[#5E5C2D]">{dog.data.role}</span>
							)}
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="mt-12">
			<h2 class="text-2xl font-semibold text-[#2f2e17] md:text-3xl">Puppy Gallery: Previous Litter</h2>
			<div class="mt-6 grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
				{previousLitterPuppies.map((dog) => (
					<article class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-black/5">
						<button
							type="button"
							class="aspect-square w-full overflow-hidden rounded-xl bg-neutral-100"
							data-lightbox-src={getDisplayImage(dog)}
							data-lightbox-alt={dog.data.label}
						>
							<img src={getDisplayImage(dog)} alt={dog.data.name} class="h-full w-full object-cover transition hover:scale-105" loading="lazy" />
						</button>
						<h3 class="mt-3 text-base font-semibold text-[#2f2e17]">{dog.data.label}</h3>
					</article>
				))}
			</div>
		</section>

		<section class="mt-12">
			<h2 class="text-2xl font-semibold text-[#2f2e17] md:text-3xl">Puppy Gallery: This Litter ({currentLitterPuppies.length})</h2>
			<div class="mt-6 grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
				{currentLitterPuppies.map((dog) => (
					<article class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-black/5">
						<button
							type="button"
							class="aspect-square w-full overflow-hidden rounded-xl bg-neutral-100"
							data-lightbox-src={getDisplayImage(dog)}
							data-lightbox-alt={dog.data.label}
						>
							<img src={getDisplayImage(dog)} alt={dog.data.name} class="h-full w-full object-cover transition hover:scale-105" loading="lazy" />
						</button>
						<h3 class="mt-3 text-base font-semibold text-[#2f2e17]">{dog.data.label}</h3>
					</article>
				))}
			</div>
		</section>

		<section class="mt-12">
			<h2 class="text-2xl font-semibold text-[#2f2e17] md:text-3xl">FAQs</h2>
			<div class="mt-6 space-y-3">
				{orderedFaqs.map((faq) => (
					<details class="group rounded-xl bg-white p-5 shadow-sm ring-1 ring-black/5">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-[#2f2e17] md:text-lg">
							<span>{faq.data.question}</span>
							<svg
								class="h-5 w-5 shrink-0 text-[#5E5C2D]/80 transition-transform duration-200 group-open:rotate-180"
								viewBox="0 0 20 20"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								aria-hidden="true"
							>
								<path d="M5 7.5L10 12.5L15 7.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</summary>
						<p class="mt-3 whitespace-pre-line text-[15px] leading-relaxed text-[#5E5C2D]/90">{faq.body}</p>
					</details>
				))}
			</div>
		</section>

		<section id="contact" class="mt-12 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-black/5 md:p-10">
			<h2 class="text-2xl font-semibold text-[#2f2e17] md:text-3xl">Contact</h2>
			<div class="mt-4 space-y-3 text-base text-[#5E5C2D]/90 md:text-lg">
				<p>
					<span class="font-semibold">Email:</span>
					<a class="ml-2 underline decoration-[#5E5C2D]/40 underline-offset-4 hover:opacity-80" href={`mailto:${contact?.email ?? 'hello@devongoldens.com'}`}>
						{contact?.email ?? 'hello@devongoldens.com'}
					</a>
				</p>
				<p>
					<span class="font-semibold">Instagram:</span>
					<a class="ml-2 underline decoration-[#5E5C2D]/40 underline-offset-4 hover:opacity-80" href={`https://instagram.com/${(contact?.instagram ?? 'devongoldens').replace('@', '')}`} target="_blank" rel="noreferrer">
						{contact?.instagram ?? '@devongoldens'}
					</a>
				</p>
				<p>
					<span class="font-semibold">Phone:</span>
					<a class="ml-2 underline decoration-[#5E5C2D]/40 underline-offset-4 hover:opacity-80" href={`tel:${(contact?.phone ?? '').replace(/\D/g, '')}`}>
						{contact?.phone ?? '(000) 000-0000'}
					</a>
				</p>
			</div>
		</section>
	</main>

	<dialog id="gallery-lightbox" class="m-auto w-[min(96vw,1000px)] rounded-2xl border-0 bg-transparent p-0 backdrop:bg-black/80">
		<div class="relative">
			<button
				type="button"
				id="lightbox-close"
				class="absolute right-3 top-3 rounded-full bg-black/65 px-3 py-1 text-sm font-semibold text-white"
			>
				Close
			</button>
			<img id="lightbox-image" src="" alt="" class="max-h-[85vh] w-full rounded-2xl object-contain bg-black" />
		</div>
	</dialog>
</Layout>

<script>
	const dialog = document.getElementById('gallery-lightbox');
	const image = document.getElementById('lightbox-image');
	const closeButton = document.getElementById('lightbox-close');
	const openers = document.querySelectorAll('[data-lightbox-src]');

	if (dialog instanceof HTMLDialogElement && image instanceof HTMLImageElement) {
		openers.forEach((opener) => {
			opener.addEventListener('click', () => {
				const src = opener.getAttribute('data-lightbox-src') || '';
				const alt = opener.getAttribute('data-lightbox-alt') || 'Gallery image';
				image.src = src;
				image.alt = alt;
				dialog.showModal();
			});
		});

		closeButton?.addEventListener('click', () => dialog.close());
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});
	}
</script>
