---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import homepage from '../content/singletons/homepage.json';
import contact from '../content/singletons/contact.json';

const [dogs, faqs] = await Promise.all([getCollection('dogs'), getCollection('faqs')]);

const byLabel = (a: (typeof dogs)[number], b: (typeof dogs)[number]) =>
	a.data.label.localeCompare(b.data.label, undefined, { numeric: true });

const parentDogs = dogs.filter((dog) => dog.data.group === 'Parents').sort(byLabel);
const previousLitterPuppies = dogs.filter((dog) => dog.data.group === 'Previous Litter').sort(byLabel);
const currentLitterPuppies = dogs.filter((dog) => dog.data.group === 'Current Litter').sort(byLabel);
const orderedFaqs = [...faqs].sort((a, b) => a.data.order - b.data.order);

const fallbackDogImages = [
	'https://images.unsplash.com/photo-1633722715463-d30f4f325e24?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1612774412771-005ed8e861d2?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1530281700549-e82e7bf110d6?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1601758228041-f3b2795255f1?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&w=1200&q=80',
	'https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&w=1200&q=80',
];

const makeSeed = (input: string) => {
	const hash = [...input].reduce((acc, char) => (acc * 31 + char.charCodeAt(0)) % 100000, 7);
	return Math.abs(hash);
};

const getDisplayImage = (entry: (typeof dogs)[number]) => {
	if (entry.data.image.startsWith('http://') || entry.data.image.startsWith('https://')) {
		return entry.data.image;
	}
	const seed = makeSeed(`${entry.data.group}-${entry.data.label}`);
	return fallbackDogImages[seed % fallbackDogImages.length];
};
---

<Layout>

	<!-- HERO -->
	<section id="hero" class="relative flex min-h-screen items-center justify-center overflow-hidden">
		<img
			src="https://images.unsplash.com/photo-1720393681064-4645912e8903?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
			alt="Golden retrievers"
			class="absolute inset-0 h-full w-full object-cover"
			loading="eager"
		/>
		<div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/40 to-black/60"></div>
		<div class="relative z-10 mx-auto max-w-4xl px-6 text-center text-white">
			<p class="mb-4 text-xs font-semibold uppercase tracking-[0.25em] text-white/70">Devon Goldens</p>
			<h1 class="text-5xl font-semibold leading-tight md:text-7xl">
				{homepage?.heroTitle ?? 'Golden Retrievers raised with love'}
			</h1>
			<p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/80">
				{homepage?.introText ?? 'Purebred Canadian Field line variety golden retrievers.'}
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a href="#gallery" class="rounded-full bg-[#FEC67C] px-8 py-3 text-sm font-semibold text-[#2f2e17] transition hover:brightness-95">
					View Puppies
				</a>
				<a href="#contact" class="rounded-full border border-white/50 px-8 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
					Get in Touch
				</a>
			</div>
		</div>
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
			<svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
			</svg>
		</div>
	</section>

	<!-- ABOUT -->
	<section id="about">
		<div class="section-banner sticky z-30 flex h-24 items-center justify-center bg-[#5E5C2D] transition-all duration-300">
			<h2 class="section-banner-title text-3xl font-semibold text-white transition-all duration-300 md:text-4xl">About Us</h2>
		</div>
		<div class="mx-auto max-w-3xl px-6 py-16 md:px-10">
			<p class="whitespace-pre-line text-lg leading-[1.9] text-neutral-700">{homepage?.aboutUs}</p>
		</div>
	</section>

	<!-- PARENTS -->
	<section id="parents" class="bg-white">
		<div class="section-banner sticky z-30 flex h-24 items-center justify-center bg-[#999A57] transition-all duration-300">
			<h2 class="section-banner-title text-3xl font-semibold text-white transition-all duration-300 md:text-4xl">Meet the Parents</h2>
		</div>
		<div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
			<div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
				{parentDogs.map((dog) => (
					<article>
						<button
							type="button"
							class="group block w-full overflow-hidden"
							data-lightbox-src={getDisplayImage(dog)}
							data-lightbox-alt={dog.data.label}
						>
							<div class="aspect-[4/3] overflow-hidden bg-neutral-100">
								<img
									src={getDisplayImage(dog)}
									alt={dog.data.name}
									class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
									loading="lazy"
								/>
							</div>
						</button>
						<div class="mt-3 flex items-baseline justify-between">
							<h3 class="text-lg font-semibold text-neutral-900">{dog.data.label}</h3>
							{dog.data.role && (
								<span class="text-xs font-medium uppercase tracking-wider text-[#5E5C2D]/70">{dog.data.role}</span>
							)}
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- PREVIOUS LITTER -->
	{previousLitterPuppies.length > 0 && (
		<section id="gallery" class="bg-[#faf9f6]">
			<div class="section-banner sticky z-30 flex h-24 items-center justify-center bg-[#FC9C51] transition-all duration-300">
				<h2 class="section-banner-title text-3xl font-semibold text-[#2f2e17] transition-all duration-300 md:text-4xl">Previous Litter</h2>
			</div>
			<div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
				<div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
					{previousLitterPuppies.map((dog) => (
						<article>
							<button
								type="button"
								class="group block w-full overflow-hidden"
								data-lightbox-src={getDisplayImage(dog)}
								data-lightbox-alt={dog.data.label}
							>
								<div class="aspect-square overflow-hidden bg-neutral-100">
									<img
										src={getDisplayImage(dog)}
										alt={dog.data.name}
										class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
										loading="lazy"
									/>
								</div>
							</button>
							<p class="mt-2 text-sm font-medium text-neutral-700">{dog.data.label}</p>
						</article>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- CURRENT LITTER -->
	<section id="current-litter" class="bg-white">
		<div class="section-banner sticky z-30 flex h-24 flex-col items-center justify-center gap-1 bg-[#FEC67C] transition-all duration-300">
			<h2 class="section-banner-title text-3xl font-semibold text-[#2f2e17] transition-all duration-300 md:text-4xl">This Litter</h2>
			<p class="section-banner-sub text-xs font-medium uppercase tracking-widest text-[#2f2e17]/60 transition-all duration-300">{currentLitterPuppies.length} puppies</p>
		</div>
		<div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
			<div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
				{currentLitterPuppies.map((dog) => (
					<article>
						<button
							type="button"
							class="group block w-full overflow-hidden"
							data-lightbox-src={getDisplayImage(dog)}
							data-lightbox-alt={dog.data.label}
						>
							<div class="aspect-square overflow-hidden bg-neutral-100">
								<img
									src={getDisplayImage(dog)}
									alt={dog.data.name}
									class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
									loading="lazy"
								/>
							</div>
						</button>
						<p class="mt-2 text-sm font-medium text-neutral-700">{dog.data.label}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section id="faq" class="bg-[#faf9f6]">
		<div class="section-banner sticky z-30 flex h-24 items-center justify-center bg-[#F9BDB0] transition-all duration-300">
			<h2 class="section-banner-title text-3xl font-semibold text-[#2f2e17] transition-all duration-300 md:text-4xl">FAQ</h2>
		</div>
		<div class="mx-auto max-w-3xl px-6 py-16 md:px-10">
			<div class="divide-y divide-neutral-200">
				{orderedFaqs.map((faq) => (
					<details class="group py-5">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4">
							<span class="text-base font-semibold text-neutral-900 md:text-lg">{faq.data.question}</span>
							<svg
								class="h-5 w-5 shrink-0 text-[#5E5C2D] transition-transform duration-200 group-open:rotate-180"
								viewBox="0 0 20 20"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								aria-hidden="true"
							>
								<path d="M5 7.5L10 12.5L15 7.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</summary>
						<p class="mt-4 whitespace-pre-line text-[15px] leading-relaxed text-neutral-600">{faq.body}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<!-- CONTACT -->
	<section id="contact" class="bg-[#A16A84]">
		<div class="section-banner no-shrink sticky z-30 flex h-24 items-center justify-center bg-[#A16A84] transition-all duration-300">
			<h2 class="section-banner-title text-3xl font-semibold text-white transition-all duration-300 md:text-4xl">Contact Us</h2>
		</div>
		<div class="mx-auto max-w-3xl px-6 py-16 text-center md:px-10">
			<p class="text-white/70">We'd love to hear from you. Reach out through any of the channels below.</p>
			<div class="mt-10 flex flex-col items-center gap-4 text-white sm:flex-row sm:justify-center">
				<a
					href={`mailto:${contact?.email ?? 'hello@devongoldens.com'}`}
					class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-medium transition hover:bg-white/20"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
					{contact?.email ?? 'hello@devongoldens.com'}
				</a>
				<a
					href={`https://instagram.com/${(contact?.instagram ?? 'devongoldens').replace('@', '')}`}
					target="_blank"
					rel="noreferrer"
					class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-medium transition hover:bg-white/20"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="3"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
					{contact?.instagram ?? '@devongoldens'}
				</a>
				<a
					href={`tel:${(contact?.phone ?? '').replace(/\D/g, '')}`}
					class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-medium transition hover:bg-white/20"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.92 17z"/></svg>
					{contact?.phone ?? '(000) 000-0000'}
				</a>
			</div>
		</div>
	</section>

	<!-- LIGHTBOX -->
	<dialog id="gallery-lightbox" class="m-auto w-[min(96vw,1100px)] border-0 bg-transparent p-0 backdrop:bg-black/90">
		<div class="relative">
			<button
				type="button"
				id="lightbox-close"
				class="absolute right-4 top-4 z-10 rounded-full bg-black/60 p-2 text-white transition hover:bg-black/80"
				aria-label="Close"
			>
				<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			<img id="lightbox-image" src="" alt="" class="max-h-[90vh] w-full object-contain" />
		</div>
	</dialog>
</Layout>

<style>
	.section-banner.is-stuck:not(.no-shrink) {
		height: 2.75rem;
	}
	.section-banner.is-stuck:not(.no-shrink) .section-banner-title {
		font-size: 1rem;
		line-height: 1.5;
	}
	.section-banner.is-stuck .section-banner-sub {
		display: none;
	}
</style>

<script>
	// Measure actual nav height so sticky banners sit flush underneath it
	const nav = document.getElementById('site-header');
	const navHeight = nav?.offsetHeight ?? 64;
	const rootMargin = `-${navHeight + 1}px 0px 0px 0px`;

	document.querySelectorAll('.section-banner').forEach((banner) => {
		// Apply precise top offset
		(banner as HTMLElement).style.top = `${navHeight}px`;

		// Zero-height sentinel so it doesn't create a gap in the flow
		const sentinel = document.createElement('div');
		sentinel.style.cssText = 'height:0;margin:0;padding:0;border:0;';
		banner.parentElement?.insertBefore(sentinel, banner);

		const observer = new IntersectionObserver(
			([entry]) => {
				banner.classList.toggle('is-stuck', !entry.isIntersecting);
			},
			{ rootMargin, threshold: 0 }
		);
		observer.observe(sentinel);
	});

	const dialog = document.getElementById('gallery-lightbox');
	const image = document.getElementById('lightbox-image');
	const closeButton = document.getElementById('lightbox-close');
	const openers = document.querySelectorAll('[data-lightbox-src]');

	if (dialog instanceof HTMLDialogElement && image instanceof HTMLImageElement) {
		openers.forEach((opener) => {
			opener.addEventListener('click', () => {
				image.src = opener.getAttribute('data-lightbox-src') || '';
				image.alt = opener.getAttribute('data-lightbox-alt') || '';
				dialog.showModal();
			});
		});

		closeButton?.addEventListener('click', () => dialog.close());
		dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });
	}
</script>
