---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import homepage from '../content/singletons/homepage.json';
import contact from '../content/singletons/contact.json';
import { getImagesFromPublicFolder, publicImageUrl } from '../lib/images';

const faqs = await getCollection('faqs');
const orderedFaqs = [...faqs].sort((a, b) => a.data.order - b.data.order);

const baileyImages = getImagesFromPublicFolder('bailey');
const dakodaImages = getImagesFromPublicFolder('dakoda');
const previousLitterImages = getImagesFromPublicFolder('previous litter');

const parents = [
	{
		id: 'bailey',
		label: 'Bailey',
		role: 'Mama',
		cover: publicImageUrl('bailey', 'PHOTO-2026-04-28-17-19-01 3.jpg'),
		coverPosition: 'center 35%',
		images: baileyImages,
	},
	{
		id: 'dakoda',
		label: 'Dakoda (Koda)',
		role: 'Mama',
		cover: publicImageUrl('dakoda', 'PHOTO-2026-04-28-17-16-48.jpg'),
		images: dakodaImages,
	},
	{
		id: 'miggy',
		label: 'Mr. Miagi (Miggy)',
		role: 'Stud',
		cover: null,
		images: [] as string[],
	},
];

const mosaicSpans = [
	'md:col-span-2 md:row-span-2',
	'',
	'md:row-span-2',
	'',
	'md:col-span-2',
	'',
	'md:row-span-2',
	'',
	'',
	'md:col-span-2 md:row-span-2',
];

const galleryData = {
	bailey: baileyImages,
	dakoda: dakodaImages,
	'previous-litter': previousLitterImages,
};

const galleryTitles: Record<string, string> = {
	bailey: 'Bailey',
	dakoda: 'Dakoda (Koda)',
	'previous-litter': 'Previous Litters',
};
---

<Layout>

	<!-- HERO -->
	<section id="hero" class="hero relative flex min-h-screen items-center justify-center overflow-hidden">
		<img
			src="/all-the-puppies.jpg"
			alt="Golden retrievers"
			class="hero-media absolute inset-0 h-full w-full object-cover object-center md:object-[center_calc(50%+100px)]"
			loading="eager"
		/>
		<div class="hero-overlay absolute inset-0 bg-gradient-to-b from-black/55 via-black/40 to-black/60"></div>
		<div class="relative z-10 mx-auto max-w-4xl px-6 text-center text-white">
			<p class="mb-4 text-xs font-semibold uppercase tracking-[0.25em] text-white/70">Devon Goldens</p>
			<h1 class="text-5xl font-semibold leading-tight md:text-7xl">
				{homepage?.heroTitle ?? 'Golden Retrievers raised with love'}
			</h1>
			<p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/80">
				{homepage?.introText ?? 'Purebred Canadian Field line variety golden retrievers.'}
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a href="#gallery" class="rounded-full bg-[#FEC67C] px-8 py-3 text-sm font-semibold text-[#2f2e17] transition hover:brightness-95">
					View Gallery
				</a>
				<a href="#contact" class="rounded-full border border-white/50 px-8 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
					Get in Touch
				</a>
			</div>
		</div>
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
			<svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
			</svg>
		</div>
	</section>

	<!-- ABOUT -->
	<section id="about">
		<div class="section-banner sticky z-30 flex h-16 items-center justify-center bg-[#5E5C2D]">
			<h2 class="section-banner-title text-lg font-semibold text-white md:text-xl">About Us</h2>
		</div>
		<div class="mx-auto max-w-3xl px-6 py-16 md:px-10">
			<p class="whitespace-pre-line text-lg leading-[1.9] text-neutral-700">{homepage?.aboutUs}</p>
		</div>
	</section>

	<!-- PARENTS -->
	<section id="parents" class="bg-white">
		<div class="section-banner sticky z-30 flex h-16 items-center justify-center bg-[#999A57]">
			<h2 class="section-banner-title text-lg font-semibold text-white md:text-xl">Meet the Parents</h2>
		</div>
		<div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
			<div class="grid grid-cols-2 gap-6 md:grid-cols-3 md:gap-8">
				{parents.map((parent) => (
					<article>
						{parent.cover ? (
							<button
								type="button"
								class="gallery-open group relative block w-full overflow-hidden"
								data-gallery={parent.id}
								data-index="0"
							>
								<div class="aspect-[4/3] overflow-hidden bg-neutral-100">
									<img
										src={parent.cover}
										alt={parent.label}
										class="h-full w-full object-cover transition duration-700 group-hover:scale-110"
										style={parent.coverPosition ? `object-position: ${parent.coverPosition}` : undefined}
										loading="lazy"
									/>
								</div>
								<div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 transition duration-300 group-hover:bg-black/25">
									<span class="translate-y-2 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100">
										<svg class="h-8 w-8 text-white drop-shadow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14zM11 8v6m-3-3h6" />
										</svg>
									</span>
								</div>
							</button>
						) : (
							<div class="flex aspect-[4/3] items-center justify-center bg-[#faf9f6]">
								<p class="px-4 text-center text-sm text-neutral-500">Photos coming soon</p>
							</div>
						)}
						<div class="mt-3 flex items-baseline justify-between gap-2">
							<h3 class="text-base font-semibold text-neutral-900 md:text-lg">{parent.label}</h3>
							<span class="text-xs font-medium uppercase tracking-wider text-[#5E5C2D]/70">{parent.role}</span>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- PREVIOUS LITTER MOSAIC -->
	{previousLitterImages.length > 0 && (
		<section id="gallery" class="bg-[#faf9f6]">
			<div class="section-banner sticky z-30 flex h-16 items-center justify-center bg-[#FC9C51]">
				<h2 class="section-banner-title text-lg font-semibold text-[#2f2e17] md:text-xl">Previous Litters</h2>
			</div>
			<div class="mx-auto max-w-7xl px-4 py-16 md:px-6">
				<div class="mosaic-grid grid grid-cols-2 gap-1 md:grid-cols-4 md:auto-rows-[180px] md:gap-1.5">
					{previousLitterImages.map((src, index) => (
						<button
							type="button"
							class={`gallery-open mosaic-item group relative overflow-hidden ${mosaicSpans[index % mosaicSpans.length]}`}
							data-gallery="previous-litter"
							data-index={index}
						>
							<img
								src={src}
								alt={`Previous litters photo ${index + 1}`}
								class="h-full w-full object-cover transition duration-700 ease-out group-hover:scale-110 group-hover:brightness-110"
								loading="lazy"
							/>
							<div class="pointer-events-none absolute inset-0 bg-[#5E5C2D]/0 transition duration-300 group-hover:bg-[#5E5C2D]/20" />
							<div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-0 transition duration-300 group-hover:opacity-100">
								<span class="rounded-full bg-white/90 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[#5E5C2D]">
									View
								</span>
							</div>
						</button>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- CURRENT LITTER -->
	<section id="current-litter" class="bg-white">
		<div class="section-banner sticky z-30 flex h-16 items-center justify-center bg-[#FEC67C]">
			<h2 class="section-banner-title text-lg font-semibold text-[#2f2e17] md:text-xl">This Litter</h2>
		</div>
		<div class="mx-auto max-w-2xl px-6 py-20 text-center md:px-10">
			<p class="font-['Playfair_Display'] text-2xl font-semibold text-[#2f2e17] md:text-3xl">
				All puppies from this litter have found their forever homes.
			</p>
			<p class="mt-5 text-base leading-relaxed text-neutral-600 md:text-lg">
				Thank you to every family who welcomed one of our pups. If you would like to be considered for a future litter, we would love to hear from you.
			</p>
			<a
				href="#contact"
				class="mt-8 inline-block rounded-full bg-[#5E5C2D] px-8 py-3 text-sm font-semibold text-white transition hover:opacity-90"
			>
				Join Our Waitlist
			</a>
		</div>
	</section>

	<!-- FAQ -->
	<section id="faq" class="bg-[#faf9f6]">
		<div class="section-banner sticky z-30 flex h-16 items-center justify-center bg-[#F9BDB0]">
			<h2 class="section-banner-title text-lg font-semibold text-[#2f2e17] md:text-xl">FAQ</h2>
		</div>
		<div class="mx-auto max-w-3xl px-6 py-16 md:px-10">
			<div class="divide-y divide-neutral-200">
				{orderedFaqs.map((faq) => (
					<details class="group py-5">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4">
							<span class="text-base font-semibold text-neutral-900 md:text-lg">{faq.data.question}</span>
							<svg
								class="h-5 w-5 shrink-0 text-[#5E5C2D] transition-transform duration-200 group-open:rotate-180"
								viewBox="0 0 20 20"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								aria-hidden="true"
							>
								<path d="M5 7.5L10 12.5L15 7.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</summary>
						<p class="mt-4 whitespace-pre-line text-[15px] leading-relaxed text-neutral-600">{faq.body}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<!-- CONTACT -->
	<section id="contact" class="bg-[#A16A84]">
		<div class="section-banner sticky z-30 flex h-16 items-center justify-center bg-[#A16A84]">
			<h2 class="section-banner-title text-lg font-semibold text-white md:text-xl">Contact Us</h2>
		</div>
		<div class="mx-auto max-w-3xl px-6 py-16 text-center md:px-10">
			<p class="text-white/70">We'd love to hear from you. Reach out through any of the channels below.</p>
			<div class="mt-10 flex flex-col items-center gap-4 text-white sm:flex-row sm:justify-center">
				<a
					href={`mailto:${contact?.email ?? 'hello@devongoldens.com'}`}
					class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-medium transition hover:bg-white/20"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
					{contact?.email ?? 'hello@devongoldens.com'}
				</a>
				<a
					href={`https://instagram.com/${(contact?.instagram ?? 'devongoldens').replace('@', '')}`}
					target="_blank"
					rel="noreferrer"
					class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-medium transition hover:bg-white/20"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="3"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
					{contact?.instagram ?? '@devongoldens'}
				</a>
				<a
					href={`tel:${(contact?.phone ?? '').replace(/\D/g, '')}`}
					class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-medium transition hover:bg-white/20"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.92 17z"/></svg>
					{contact?.phone ?? '(000) 000-0000'}
				</a>
			</div>
		</div>
	</section>

	<!-- LIGHTBOX -->
	<dialog id="gallery-lightbox" class="lightbox">
		<div class="lightbox-inner">
			<div class="lightbox-header">
				<div class="lightbox-header-info">
					<p id="lightbox-title" class="lightbox-title"></p>
					<p id="lightbox-counter" class="lightbox-counter"></p>
				</div>
				<button
					type="button"
					id="lightbox-close"
					class="rounded-full bg-white/10 p-2.5 text-white transition hover:bg-white/20"
					aria-label="Close"
				>
					<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>

			<div class="lightbox-stage">
				<button
					type="button"
					id="lightbox-prev"
					class="lightbox-nav"
					aria-label="Previous image"
				>
					<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
					</svg>
				</button>
				<img id="lightbox-image" src="" alt="" class="lightbox-image" />
				<button
					type="button"
					id="lightbox-next"
					class="lightbox-nav"
					aria-label="Next image"
				>
					<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
					</svg>
				</button>
			</div>
		</div>
	</dialog>

	<script type="application/json" id="gallery-data" set:html={JSON.stringify(galleryData)} />
	<script type="application/json" id="gallery-titles" set:html={JSON.stringify(galleryTitles)} />
</Layout>

<style>
	.mosaic-item {
		min-height: 140px;
	}

	@media (max-width: 767px) {
		#hero {
			min-height: 100svh;
			min-height: 100dvh;
			margin-top: calc(-1 * env(safe-area-inset-top, 0px));
			padding-top: env(safe-area-inset-top, 0px);
		}

		#hero .hero-media,
		#hero .hero-overlay {
			top: calc(-1 * env(safe-area-inset-top, 0px));
			height: calc(100% + env(safe-area-inset-top, 0px));
			min-height: calc(100svh + env(safe-area-inset-top, 0px));
		}
	}

	#gallery-lightbox.lightbox {
		margin: 0;
		padding: 0;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		background: #0a0a0a;
	}

	#gallery-lightbox.lightbox::backdrop {
		background: #0a0a0a;
	}

	.lightbox-inner {
		display: flex;
		flex-direction: column;
		width: 100%;
		height: 100%;
		min-height: 100dvh;
	}

	.lightbox-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.25rem;
		flex-shrink: 0;
	}

	.lightbox-header-info {
		min-width: 0;
	}

	.lightbox-title {
		font-family: 'Playfair Display', serif;
		font-size: 1.25rem;
		font-weight: 600;
		color: white;
		line-height: 1.3;
	}

	.lightbox-counter {
		margin-top: 0.25rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.55);
	}

	@media (min-width: 768px) {
		.lightbox-title {
			font-size: 1.5rem;
		}
	}

	.lightbox-stage {
		position: relative;
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 1rem 2rem;
		min-height: 0;
	}

	.lightbox-image {
		max-height: calc(100dvh - 5rem);
		max-width: min(1100px, 92vw);
		width: auto;
		height: auto;
		object-fit: contain;
	}

	.lightbox-nav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		z-index: 10;
		border-radius: 9999px;
		background: rgba(255, 255, 255, 0.1);
		padding: 0.75rem;
		color: white;
		transition: background 0.2s;
	}

	.lightbox-nav:hover {
		background: rgba(255, 255, 255, 0.2);
	}

	#lightbox-prev {
		left: 1rem;
	}

	#lightbox-next {
		right: 1rem;
	}
</style>

<script>
	const galleryDataEl = document.getElementById('gallery-data');
	const galleryTitlesEl = document.getElementById('gallery-titles');
	const galleryData: Record<string, string[]> = galleryDataEl
		? JSON.parse(galleryDataEl.textContent || '{}')
		: {};
	const galleryTitles: Record<string, string> = galleryTitlesEl
		? JSON.parse(galleryTitlesEl.textContent || '{}')
		: {};

	const dialog = document.getElementById('gallery-lightbox');
	const image = document.getElementById('lightbox-image');
	const title = document.getElementById('lightbox-title');
	const counter = document.getElementById('lightbox-counter');
	const closeButton = document.getElementById('lightbox-close');
	const prevButton = document.getElementById('lightbox-prev');
	const nextButton = document.getElementById('lightbox-next');

	let activeGallery: string[] = [];
	let activeIndex = 0;
	let activeGalleryId = '';

	const showImage = () => {
		if (!(image instanceof HTMLImageElement) || !counter || !title) return;
		image.src = activeGallery[activeIndex] || '';
		image.alt = `${galleryTitles[activeGalleryId] || 'Gallery'} image ${activeIndex + 1}`;
		title.textContent = galleryTitles[activeGalleryId] || 'Gallery';
		counter.textContent = `${activeIndex + 1} / ${activeGallery.length}`;
	};

	const openGallery = (galleryId: string, index: number) => {
		if (!(dialog instanceof HTMLDialogElement)) return;
		activeGallery = galleryData[galleryId] || [];
		if (!activeGallery.length) return;
		activeGalleryId = galleryId;
		activeIndex = index;
		showImage();
		dialog.showModal();
	};

	const step = (direction: number) => {
		if (!activeGallery.length) return;
		activeIndex = (activeIndex + direction + activeGallery.length) % activeGallery.length;
		showImage();
	};

	document.querySelectorAll('.gallery-open').forEach((opener) => {
		opener.addEventListener('click', () => {
			const galleryId = opener.getAttribute('data-gallery') || '';
			const index = Number(opener.getAttribute('data-index') || '0');
			openGallery(galleryId, index);
		});
	});

	closeButton?.addEventListener('click', () => dialog instanceof HTMLDialogElement && dialog.close());
	prevButton?.addEventListener('click', () => step(-1));
	nextButton?.addEventListener('click', () => step(1));

	dialog?.addEventListener('click', (e) => {
		if (e.target === dialog && dialog instanceof HTMLDialogElement) dialog.close();
	});

	document.addEventListener('keydown', (e) => {
		if (!(dialog instanceof HTMLDialogElement) || !dialog.open) return;
		if (e.key === 'ArrowLeft') step(-1);
		if (e.key === 'ArrowRight') step(1);
		if (e.key === 'Escape') dialog.close();
	});

	// Sticky section banners
	const nav = document.getElementById('site-header');

	const updateBannerTop = () => {
		const navHeight = nav?.offsetHeight ?? 64;
		document.querySelectorAll('.section-banner').forEach((banner) => {
			(banner as HTMLElement).style.top = `${navHeight}px`;
		});
	};

	updateBannerTop();

	if (nav) {
		new ResizeObserver(updateBannerTop).observe(nav);
	}
</script>
